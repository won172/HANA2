generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id   String @id @default(cuid())
  name String
  role String // ADMIN, CLUB_USER, APPROVER, POS

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
}

model Organization {
  id   String @id @default(cuid())
  name String
  type String // ISSUER, CLUB

  users   User[]
  budgets Budget[] @relation("OrgBudgets")
  issuedBudgets Budget[] @relation("IssuedBudgets")
  transactions Transaction[]
  budgetRequests BudgetRequest[]
  policyExceptionRequests PolicyExceptionRequest[]

  createdAt DateTime @default(now())
}

model AnchorRecord {
  id          String   @id @default(cuid())
  eventType   String
  entityType  String
  entityId    String
  payloadHash String
  chainStatus String   @default("PENDING") // PENDING, ANCHORED, FAILED
  txHash      String?
  anchoredAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([eventType, createdAt])
  @@index([chainStatus, createdAt])
}

model Merchant {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Budget {
  id                  String   @id @default(cuid())
  name                String
  totalAmount         Int
  currentBalance      Int
  validFrom           DateTime
  validUntil          DateTime
  status              String   @default("ACTIVE") // ACTIVE, EXPIRED, RECALLED

  organizationId      String
  organization        Organization @relation("OrgBudgets", fields: [organizationId], references: [id])

  issuerOrganizationId String
  issuerOrganization   Organization @relation("IssuedBudgets", fields: [issuerOrganizationId], references: [id])
  sourceRequestId      String?  @unique
  sourceRequest        BudgetRequest? @relation(fields: [sourceRequestId], references: [id])

  policy        Policy?
  transactions  Transaction[]
  policyExceptionRequests PolicyExceptionRequest[]
  ledgerEntries LedgerEntry[]
  settlement    BudgetSettlement?

  createdAt DateTime @default(now())
}

model Policy {
  id                String  @id @default(cuid())
  budgetId          String  @unique
  budget            Budget  @relation(fields: [budgetId], references: [id])
  displayName       String? @default("정책")
  summary           String?
  policySource      String  @default("MANUAL") // MANUAL, AI
  aiConfidence      Float?

  allowedCategories String  @default("[]") // JSON string array
  blockedCategories String  @default("[]") // JSON string array
  blockedKeywords   String  @default("[]") // JSON string array
  allowedKeywords   String  @default("[]") // JSON string array
  categoryAutoApproveRules String @default("{}") // JSON object
  eventCategories   String  @default("[]") // JSON string array
  autoApproveLimit  Int     @default(50000)
  manualReviewLimit Int     @default(150000)
  allowNewMerchant  Boolean @default(false)
  quietHoursStart   Int?
  quietHoursEnd     Int?
  eventWindowStart  DateTime?
  eventWindowEnd    DateTime?
  templateKey       String?
}

model Transaction {
  id                String   @id @default(cuid())
  budgetId          String
  budget            Budget   @relation(fields: [budgetId], references: [id])

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])

  merchantName      String
  amount            Int
  itemDescription   String
  requestedCategory String
  resolvedCategory  String?

  status            String   // APPROVED, NOTIFIED, PENDING, DECLINED
  reviewReason      String?
  additionalExplanation String?
  adminComment      String?
  resubmissionCount Int      @default(0)
  lastSubmittedAt   DateTime?

  // AI 분석 결과
  aiSuggestedCategory String?
  aiRiskScore         Int?
  aiRiskLevel         String?  // LOW, MEDIUM, HIGH
  aiExplanation       String?

  ledgerEntries     LedgerEntry[]

  createdAt         DateTime @default(now())
}

model BudgetRequest {
  id                   String   @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  title                String
  purpose              String
  requestedAmount      Int
  requestedCategories  String   @default("[]")
  requestedPeriodStart DateTime
  requestedPeriodEnd   DateTime
  status               String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewerComment      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  issuedBudget Budget?
}

model BudgetSettlement {
  id           String   @id @default(cuid())
  budgetId      String   @unique
  budget        Budget   @relation(fields: [budgetId], references: [id])
  status        String   @default("SUBMITTED") // SUBMITTED, REVIEWED
  reportNote    String
  reclaimAmount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PolicyExceptionRequest {
  id                     String   @id @default(cuid())
  budgetId               String
  budget                 Budget   @relation(fields: [budgetId], references: [id])
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id])
  merchantName           String
  amount                 Int
  requestedCategory      String
  itemDescription        String
  justification          String
  status                 String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminComment           String?
  submissionWindowLabel  String
  submissionWindowStart  Int
  submissionWindowEnd    Int
  reviewedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([budgetId, createdAt])
  @@index([organizationId, status, createdAt])
}

model LedgerEntry {
  id             String   @id @default(cuid())
  budgetId       String
  budget         Budget   @relation(fields: [budgetId], references: [id])

  transactionId  String?
  transaction    Transaction? @relation(fields: [transactionId], references: [id])

  type           String   // ISSUE, SPEND, REFUND, EXPIRE_RECALL
  amount         Int
  balanceAfter   Int
  description    String

  createdAt      DateTime @default(now())
}
